[user]
	email = topi@topikettunen.com
	name = Topi Kettunen
[alias]
	s = status -sb
	c = commit
	cm = commit -m
	d = diff
	b = branch -v
	nb = checkout -b
	conflicts = diff --name-only --diff-filter=U
	tweaks = !git add . && git commit -m "Tweaks" && git push
        root = rev-parse --show-toplevel
[core]
	autocrlf = input
[pull]
	rebase = false
[init]
	defaultBranch = main
[push]
	autoSetupRemote = true
